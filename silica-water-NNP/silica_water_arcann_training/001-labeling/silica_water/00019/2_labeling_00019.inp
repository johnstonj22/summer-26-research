@SET SYSNAME 2_labeling_00019

&GLOBAL
PRINT_LEVEL LOW
PREFERRED_FFT_LIBRARY FFTW3
EXTENDED_FFT_LENGTHS FALSE
PROJECT ${SYSNAME}
RUN_TYPE ENERGY_FORCE
PREFERRED_DIAG_LIBRARY ScaLAPACK
WALLTIME 3600.0
&END GLOBAL

&FORCE_EVAL
METHOD QS

&DFT
BASIS_SET_FILE_NAME   GTH_BASIS_SETS
POTENTIAL_FILE_NAME   GTH_POTENTIALS
WFN_RESTART_FILE_NAME labeling_00019-SCF.wfn
SORT_BASIS EXP
CHARGE 0
MULTIPLICITY 1
LSD

&MGRID
CUTOFF 400
REL_CUTOFF 50
NGRIDS 5
&END MGRID

&POISSON
PERIODIC XYZ
&END

&SCF
MAX_SCF 1000
EPS_SCF 1.0E-6
SCF_GUESS RESTART

&OT
PRECONDITIONER  FULL_SINGLE_INVERSE
MINIMIZER       DIIS
N_HISTORY_VEC   7
&END OT

&PRINT
&RESTART
FILENAME labeling_00019-SCF.wfn
LOG_PRINT_KEY
BACKUP_COPIES 0
&EACH
QS_SCF 0
JUST_ENERGY 1
&END EACH
COMMON_ITERATION_LEVELS 1
ADD_LAST NUMERIC
&END RESTART
&RESTART_HISTORY OFF
&END RESTART_HISTORY
&END PRINT
&END SCF

&QS
METHOD GPW
EPS_DEFAULT 1.0E-10
EXTRAPOLATION ASPC
&END QS

&XC
&XC_FUNCTIONAL
&PBE
&END PBE
&END XC_FUNCTIONAL
&END XC
&END DFT

&SUBSYS
&CELL
ABC [angstrom] 20.251 14.32 35.707675
ALPHA_BETA_GAMMA [deg] 90.0 90.0 90.0
&END CELL
&TOPOLOGY
COORD_FILE_FORMAT XYZ
COORD_FILE_NAME labeling_00019.xyz
&CENTER_COORDINATES
&END CENTER_COORDINATES
&END TOPOLOGY
&KIND Si
BASIS_SET           DZVP-GTH
POTENTIAL           GTH-PBE-q4
&END KIND
&KIND O
BASIS_SET           DZVP-GTH
POTENTIAL           GTH-PBE-q6
&END KIND
&KIND H
BASIS_SET           DZVP-GTH
POTENTIAL           GTH-PBE-q1
&END KIND
&END SUBSYS

&PRINT
&PROGRAM_RUN_INFO
FILENAME =${SYSNAME}-Force_Eval.fe
LOG_PRINT_KEY
&EACH
JUST_ENERGY 1
&END EACH
ADD_LAST NUMERIC
&END PROGRAM_RUN_INFO
&FORCES
FILENAME =${SYSNAME}-Forces.for
LOG_PRINT_KEY
&EACH
JUST_ENERGY 1
&END EACH
ADD_LAST NUMERIC
&END FORCES
&END PRINT
&END FORCE_EVAL
